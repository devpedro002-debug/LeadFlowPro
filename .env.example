# -----------------------------------------------------------------------------
# Configurações do Banco de Dados (Prisma)
# -----------------------------------------------------------------------------
# URL de conexão direta ao banco (Supabase). Use para migrate deploy.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# Configurações do Supabase (Autenticação / Cliente)
# -----------------------------------------------------------------------------
# Encontre esses valores em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="sb_secret_..."
